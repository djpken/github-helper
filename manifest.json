{
  "manifest_version": 3,
  "name": "GitHub Helper",
  "version": "0.0.1",
  "description": "A Chrome extension (Manifest V3).",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["src/content.ts"]
    }
  ],
  "permissions": []
}
